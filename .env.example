# TVBox Manager 环境变量配置
# 复制本文件为 .env 并填写实际值

# 持久化数据目录（可指定任意宿主机路径，默认为项目目录下的 ./data）
# 示例：DATA_DIR=/opt/tvbox-data 或 DATA_DIR=/mnt/nas/tvbox
DATA_DIR=./data

# Flask Session 加密密钥（生产环境请替换为随机字符串，重要！）
SECRET_KEY=your-secret-key-here-change-me

# 注册邀请码（用于控制谁可以注册账号）
REG_CODE=888888

# 数据库文件路径（Docker 部署无需修改）
DB_PATH=/app/data/database.db
